  "onClick": "{{\n  (() => {\n    if (!login_usuario.text || !senha_usuario.text || !perfil_usuario.selectedOptionValue) {\n      return showAlert('Os campos Login, Senha e Perfil são obrigatórios!', 'warning');\n    }\n    \n    return Tabela_Cad_usuario.run()\n      .then(() => {\n        showAlert('Usuário cadastrado!', 'success');\n        resetWidget(\"login_usuario\");\n        resetWidget(\"senha_usuario\");\n        resetWidget(\"perfil_usuario\");\n        resetWidget(\"email_usuario\");\n      })\n      .catch(() => showAlert('Erro ao cadastrar', 'error'));\n  })()\n}}\n",
